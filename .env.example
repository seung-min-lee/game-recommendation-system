# Steam
STEAM_API_KEY=your_steam_api_key

# ElastiCache Redis (AWS 배포 시 엔드포인트로 교체)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL=3600

# RDS MySQL
DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
DB_PORT=3306
DB_NAME=gamefinder
DB_USER=admin
DB_PASSWORD=your_password

# Snowflake
SNOWFLAKE_ACCOUNT=your_account.ap-northeast-2.aws
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=GAME_DW
SNOWFLAKE_SCHEMA=GOLD
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYSADMIN

# Airflow (EKS 내부 주소)
AIRFLOW_BASE_URL=http://airflow-webserver.airflow.svc.cluster.local:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_DAG_ID=game_pipeline
